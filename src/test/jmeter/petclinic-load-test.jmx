              <stringProp name="ConstantTimer.delay">${__Random(${THINK_TIME_MIN},${THINK_TIME_MAX})}</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>

          <!-- Search with dynamic lastname parameter -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /owners (search)" enabled="true">
