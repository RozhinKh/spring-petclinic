              <stringProp name="ConstantTimer.delay">${__Random(${THINK_TIME_MIN},${THINK_TIME_MAX})}</stringProp>
            </ConstantTimer>
            <hashTree/>
          </hashTree>

          <!-- Scenario 5: GET /owners/new (create owner form) -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="GET /owners/new" enabled="true">
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments" guiclass="HTTPArgumentsPanel" testclass="Arguments" testname="User Defined Variables" enabled="true">
