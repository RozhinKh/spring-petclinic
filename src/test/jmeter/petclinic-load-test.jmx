        <!-- Results Collector for CSV export -->
        <ResultCollector guiclass="SimpleDataWriterGui" testclass="ResultCollector" testname="Save Results to CSV" enabled="true">
          <elementProp name="ResultCollector.sample_save_config" elementType="SampleSaveConfiguration">
            <stringProp name="ideal_only">true</stringProp>
            <stringProp name="connect_wait_time">true</stringProp>
            <stringProp name="latency">true</stringProp>
            <stringProp name="sample_count">true</stringProp>
            <stringProp name="idle_time">true</stringProp>
            <stringProp name="bytes">true</stringProp>
            <stringProp name="sent_bytes">true</stringProp>
            <stringProp name="url">true</stringProp>
            <stringProp name="thread_counts">true</stringProp>
            <stringProp name="data_type">true</stringProp>
            <stringProp name="code">true</stringProp>
            <stringProp name="message">true</stringProp>
            <stringProp name="response_data">false</stringProp>
            <stringProp name="response_data_on_error">false</stringProp>
            <stringProp name="response_headers">false</stringProp>
            <stringProp name="samplerData">false</stringProp>
            <stringProp name="xml">false</stringProp>
            <stringProp name="field_names">true</stringProp>
            <stringProp name="time_stamp">true</stringProp>
            <stringProp name="success">true</stringProp>
            <stringProp name="label">true</stringProp>
            <stringProp name="thread_name">true</stringProp>
            <stringProp name="filename">target/jmeter-results-light-100.csv</stringProp>
