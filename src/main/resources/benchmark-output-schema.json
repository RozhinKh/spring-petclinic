{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JMH Benchmark Results Schema",
  "description": "Multi-variant JMH benchmark results from PetClinic performance testing",
  "type": "object",
  "required": ["timestamp", "variantCount", "variants"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when results were generated"
    },
    "variantCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of code variants benchmarked"
    },
    "variants": {
      "type": "array",
      "description": "Array of results per variant",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["variant", "timestamp", "benchmarks"],
        "properties": {
          "variant": {
            "type": "string",
            "enum": ["java17-baseline", "java21-traditional", "java21-virtual"],
            "description": "Variant identifier"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when this variant was benchmarked"
          },
          "benchmarks": {
            "type": "array",
            "description": "Array of benchmark measurements for this variant",
            "items": {
              "type": "object",
              "required": ["name", "benchmark_type", "mode", "unit", "value", "score"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Short benchmark method name (e.g., 'getOwners', 'coldStartup')"
                },
                "benchmark_type": {
                  "type": "string",
                  "enum": ["startup", "latency", "throughput", "memory", "other"],
                  "description": "Category of benchmark"
                },
                "full_name": {
                  "type": "string",
                  "description": "Fully qualified benchmark name (e.g., 'org.springframework.samples.petclinic.benchmark.LatencyBenchmark.getOwners')"
                },
                "mode": {
                  "type": "string",
                  "enum": ["AverageTime", "Throughput", "SampleTime", "SingleShotTime", "All"],
                  "description": "JMH measurement mode"
                },
                "unit": {
                  "type": "string",
                  "description": "Measurement unit (e.g., 'ms', 'ops/s', 'bytes')"
                },
                "value": {
                  "type": "number",
                  "description": "Primary measurement value (score)"
                },
                "score": {
                  "type": "number",
                  "description": "Numeric score from JMH benchmark"
                },
                "std_dev": {
                  "type": "number",
                  "description": "Standard deviation (error margin)"
                },
                "min": {
                  "type": "number",
                  "description": "Minimum value from confidence interval (lower bound)"
                },
                "max": {
                  "type": "number",
                  "description": "Maximum value from confidence interval (upper bound)"
                },
                "variant": {
                  "type": "string",
                  "enum": ["java17-baseline", "java21-traditional", "java21-virtual"],
                  "description": "Variant this benchmark result belongs to"
                }
              }
            }
          }
        }
      }
    }
  }
}
